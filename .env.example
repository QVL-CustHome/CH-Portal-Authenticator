# Port d'ecoute du serveur Node (le Gateway pointe auth_front_url vers ce port)
PORT=3000

# URL du CH-Api-GateWay vers lequel le serveur proxifie les appels /api
GATEWAY_URL=http://localhost:8080

# Origines de portails autorisées comme redirection après login (CSV, anti open-redirect).
# Chaque portail appelle .../login?redirect=<son URL> ; seules ces origines sont honorées.
# Défaut (dev) : le portail admin. En prod : lister les domaines réels des portails.
VITE_TRUSTED_REDIRECT_ORIGINS=http://localhost:3001
